pkgname=theonix-config
pkgver=0.1.0
pkgrel=8
pkgdesc="Theonix OS configuration, branding, and helper scripts"
arch=('any')
url="https://github.com/kelvinkbk/Theonix-OS"
license=('MIT')
depends=('bash' 'qt6-base' 'plasma-desktop')
source=("local-source::git+file://${PWD%/*/*}/.git") # Placeholder
md5sums=('SKIP')

prepare() {
    # Copy src-files into srcdir
    if [ -d "$srcdir/../../../packages/theonix-config/src-files" ]; then
        cp -r "$srcdir/../../../packages/theonix-config/src-files" "$srcdir/"
    elif [ -d "$srcdir/local-source/packages/theonix-config/src-files" ]; then
        cp -r "$srcdir/local-source/packages/theonix-config/src-files" "$srcdir/"
    fi
}

package() {
    # Install Theonix configuration and themes from our new src-files dir
    cd "$srcdir/src-files"
    install -Dm644 etc/theonix/logo.png "$pkgdir/etc/theonix/logo.png"
    install -Dm644 etc/theonix/theme.qss "$pkgdir/etc/theonix/theme.qss"
    install -Dm644 etc/theonix/trusted_domains.conf "$pkgdir/etc/theonix/trusted_domains.conf"
    
    # Install Theonix wallpapers
    install -Dm644 usr/share/wallpapers/theonix/theonix-default.png \
        "$pkgdir/usr/share/wallpapers/theonix/theonix-default.png"
    install -Dm644 usr/share/wallpapers/theonix/theonix-nebula.png \
        "$pkgdir/usr/share/wallpapers/theonix/theonix-nebula.png"

    # Install KDE skel config (sets default wallpaper for new users)
    install -Dm644 etc/skel/.config/plasma-wallpaper.conf \
        "$pkgdir/etc/skel/.config/plasma-wallpaper.conf"
    install -Dm644 etc/skel/.config/mimeapps.list \
        "$pkgdir/etc/skel/.config/mimeapps.list"

    # Desktop MIME handlers are installed by their respective packages

    # Install helper scripts from the main profile dir
    cd "$srcdir/local-source/profile/airootfs"
    install -Dm755 usr/local/bin/force-resolution.sh "$pkgdir/usr/bin/force-resolution.sh"
    install -Dm755 usr/local/bin/theonix-enable-ssh "$pkgdir/usr/bin/theonix-enable-ssh"
}
