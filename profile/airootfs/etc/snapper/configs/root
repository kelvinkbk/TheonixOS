SUBVOLUME="/"
FSTYPE="btrfs"

# Users and groups allowed to work with this config (in addition to root)
ALLOW_USERS=""
ALLOW_GROUPS="wheel"

# Sync ACL of .snapshots directory with snapper config
SYNC_ACL="yes"

# Run timeline snapshots: yes/no
TIMELINE_CREATE="yes"
TIMELINE_CLEANUP="yes"

# Minimum age (in seconds) of snapshots to be deleted in cleanup
NUMBER_MIN_AGE="1800"
TIMELINE_MIN_AGE="1800"

# Maximum number of snapshots to keep per category
# Keep more daily/weekly for safety on a rolling release
NUMBER_LIMIT="10"
NUMBER_LIMIT_IMPORTANT="10"

TIMELINE_LIMIT_HOURLY="3"
TIMELINE_LIMIT_DAILY="7"
TIMELINE_LIMIT_WEEKLY="2"
TIMELINE_LIMIT_MONTHLY="2"
TIMELINE_LIMIT_YEARLY="0"

# Empty/pre-defined snapshots to keep for safety (pacman pre-post pairs)
EMPTY_PRE_POST_CLEANUP="yes"
EMPTY_PRE_POST_MIN_AGE="1800"
