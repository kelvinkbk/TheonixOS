#!/usr/bin/env bash
# =============================================================================
# Theonix OS — .git-hooks/pre-commit
# =============================================================================
# Pre-commit hook that blocks commits containing security-sensitive files.
# Install: cp .git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or use:  git config core.hooksPath .git-hooks
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Colours (only when stdout is a TTY)
# ---------------------------------------------------------------------------
if [[ -t 1 ]]; then
    RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'
else
    RED=''; YELLOW=''; NC=''; GREEN=''
fi

ERRORS=0

echo "==> Theonix OS pre-commit security checks"

# ---------------------------------------------------------------------------
# 1. Block shadow / gshadow files
# ---------------------------------------------------------------------------
SENSITIVE_FILES=(
    "etc/shadow"
    "etc/shadow-"
    "etc/gshadow"
    "etc/gshadow-"
)

for f in "${SENSITIVE_FILES[@]}"; do
    if git diff --cached --name-only | grep -qE "(^|/)${f}$"; then
        echo -e "${RED}ERROR: Blocked commit: credential file staged: ${f}${NC}" >&2
        echo -e "${YELLOW}       Remove it with: git rm --cached '${f}'${NC}" >&2
        echo -e "${YELLOW}       It is generated at build time by scripts/generate_shadow.sh${NC}" >&2
        ERRORS=$(( ERRORS + 1 ))
    fi
done

# ---------------------------------------------------------------------------
# 2. Block private keys
# ---------------------------------------------------------------------------
PRIVATE_KEY_PATTERNS=(
    "\.key$"
    "\.pem$"
    "\.p12$"
    "_rsa$"
    "_dsa$"
    "_ecdsa$"
    "_ed25519$"
)

for pattern in "${PRIVATE_KEY_PATTERNS[@]}"; do
    while IFS= read -r staged_file; do
        if [[ -n "${staged_file}" ]]; then
            # Check if file content looks like a PEM private key
            if git show ":${staged_file}" 2>/dev/null | grep -q "BEGIN.*PRIVATE KEY"; then
                echo -e "${RED}ERROR: Blocked commit: private key detected: ${staged_file}${NC}" >&2
                ERRORS=$(( ERRORS + 1 ))
            fi
        fi
    done < <(git diff --cached --name-only | grep -E "${pattern}" || true)
done

# ---------------------------------------------------------------------------
# 3. Block ISO and large binary build artifacts
# ---------------------------------------------------------------------------
BINARY_PATTERNS=(
    "\.iso$"
    "efiboot\.img$"
    "rootfs\.img$"
)

for pattern in "${BINARY_PATTERNS[@]}"; do
    while IFS= read -r staged_file; do
        if [[ -n "${staged_file}" ]]; then
            echo -e "${RED}ERROR: Blocked commit: build artifact staged: ${staged_file}${NC}" >&2
            echo -e "${YELLOW}       Add to .gitignore and run: git rm --cached '${staged_file}'${NC}" >&2
            ERRORS=$(( ERRORS + 1 ))
        fi
    done < <(git diff --cached --name-only | grep -E "${pattern}" || true)
done

# ---------------------------------------------------------------------------
# 4. ShellCheck staged .sh files
# ---------------------------------------------------------------------------
if command -v shellcheck &>/dev/null; then
    while IFS= read -r sh_file; do
        if [[ -n "${sh_file}" && -f "${sh_file}" ]]; then
            if ! shellcheck --severity=warning "${sh_file}"; then
                echo -e "${RED}ERROR: ShellCheck failed on: ${sh_file}${NC}" >&2
                ERRORS=$(( ERRORS + 1 ))
            fi
        fi
    done < <(git diff --cached --name-only | grep -E "\.sh$" || true)
else
    echo -e "${YELLOW}WARN: shellcheck not found — skipping shell script linting${NC}"
fi

# ---------------------------------------------------------------------------
# Final result
# ---------------------------------------------------------------------------
if [[ ${ERRORS} -gt 0 ]]; then
    echo -e "${RED}==> Pre-commit FAILED: ${ERRORS} error(s) found. Commit blocked.${NC}" >&2
    exit 1
fi

echo -e "${GREEN}==> Pre-commit checks passed.${NC}"
exit 0
